# LocalCheck — Expo app environment variables
# Copy to artifacts/mobile/.env and fill in your values for local dev.
# For builds/CI, set the same vars as EAS environment variables on the
# production (and preview/development) environments in the Expo dashboard.
#
# NOTE: only variables prefixed EXPO_PUBLIC_ are exposed to the app bundle.
# They are read via process.env.EXPO_PUBLIC_* at build/bundle time, so only
# ever put publishable/anon values here — never a service_role or private key.

# ── Required (app can't reach the backend without these) ─────────────────────
# Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-anon-key-here

# ── Optional (feature-specific) ──────────────────────────────────────────────
# Mapbox public token (pk.…). Without it the map shows a "MAPBOX KEY NEEDED"
# placeholder; the rest of the app works. Get a free token at mapbox.com.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# ── Legacy / Replit web-serve only — do NOT set for the production iOS app ────
# EXPO_PUBLIC_DOMAIN / EXPO_PUBLIC_REPL_ID / REPLIT_* / BASE_PATH / PORT are used
# only by scripts/build.js + server/serve.js (the old Replit web export) and by
# the AddCourtModal photo-verify fetch (POST ${EXPO_PUBLIC_DOMAIN}/api/courts/verify),
# which has NO backend in this repo. Setting EXPO_PUBLIC_DOMAIN in production would
# only matter once a verification API is actually deployed.
# EXPO_PUBLIC_DOMAIN=
