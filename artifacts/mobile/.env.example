# LocalCheck — Expo app environment variables
# Copy to artifacts/mobile/.env and fill in your values.
# These are also set as Replit Secrets (EXPO_PUBLIC_* vars are read at build/dev time).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here
