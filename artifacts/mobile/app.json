{
  "expo": {
    "name": "LocalCheck",
    "slug": "localcheck",
    "owner": "agenticjess-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "localcheck",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101010"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.realjess.localcheck",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "LocalCheck uses your location to find courts near you and show who's playing nearby.",
        "NSCameraUsageDescription": "LocalCheck uses your camera to photograph and verify a court you're adding.",
        "NSPhotoLibraryUsageDescription": "LocalCheck lets you attach a photo to verify a court you're adding."
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "com.realjess.localcheck",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LocalCheck uses your location to find courts near you and show who's playing nearby."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LocalCheck lets you attach a photo to verify a court you're adding.",
          "cameraPermission": "LocalCheck uses your camera to photograph and verify a court you're adding."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "9c906173-0258-45a9-a3fe-786cda373c66"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/9c906173-0258-45a9-a3fe-786cda373c66"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    }
  }
}